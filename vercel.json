{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/privacy-policy", "destination": "/privacy-policy.html" },
    { "source": "/terms-of-use", "destination": "/terms-of-use.html" },
    { "source": "/marketing", "destination": "/marketing.html" },
    { "source": "/help", "destination": "/help.html" },
    { "source": "/support", "destination": "/help.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
